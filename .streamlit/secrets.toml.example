# Copia este archivo a  secrets.toml  y completa los valores.
# En Streamlit Community Cloud, pega este contenido en  Settings → Secrets.

# Contraseña de acceso al dashboard
password = "cambia-esta-clave"

# API key de Apollo (Settings → Integrations → API en Apollo).
# Necesaria para la página "Apollo en vivo". Requiere plan con acceso a API.
apollo_api_key = "TU_API_KEY_DE_APOLLO"
